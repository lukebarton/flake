font-family = "BlexMono Nerd Font"
font-size = 14

theme = Monokai Pro
# custom-shader = ./shaders/bloom.glsl
custom-shader = ./shaders/cursor_blaze.glsl
custom-shader = ./shaders/cursor_smear.glsl


background-opacity = 0.90
background-blur-radius = 20
selection-invert-fg-bg = true
bold-is-bright = true
# minimum-contrast = 2
cursor-style = block
cursor-style-blink = true
cursor-invert-fg-bg = true
cursor-opacity = .8

keybind = cmd+f=toggle_split_zoom
keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:bottom
keybind = cmd+k=goto_split:top
keybind = cmd+l=goto_split:right
keybind = cmd+shift+j=new_split:down
keybind = cmd+shift+l=new_split:right
